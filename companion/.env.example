# Localhost bind settings
COMPANION_HOST=127.0.0.1
COMPANION_PORT=7261
# Optional shared-secret bearer token. If set, plugin settings must use the same token.
COMPANION_TOKEN=
# sqlite-vec database location
COMPANION_DB=./data/companion.db

# Embedding provider: openai or ollama
COMPANION_EMBEDDING_PROVIDER=openai
COMPANION_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI-compatible embeddings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# Ollama embeddings
OLLAMA_HOST=http://127.0.0.1:11434
