{
  "name": "obsidian-copilot-companion",
  "version": "0.0.1",
  "private": true,
  "description": "Localhost vector companion for the Copilot for Obsidian plugin (Phase 1 pull indexer).",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "seed": "tsx src/seed.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "tsx --test src/index/chunker.test.ts src/vault/patterns.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
